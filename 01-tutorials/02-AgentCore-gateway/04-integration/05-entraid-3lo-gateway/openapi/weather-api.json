{
  "openapi": "3.0.0",
  "info": {
    "title": "Weather API",
    "version": "1.0.0",
    "description": "Simple weather API protected by EntraID OAuth"
  },
  "servers": [
    {
      "url": "https://<API_GATEWAY_ID>.execute-api.<REGION>.amazonaws.com",
      "description": "Weather API endpoint (replaced by setup.sh)"
    }
  ],
  "paths": {
    "/weather": {
      "get": {
        "operationId": "getWeather",
        "summary": "Get weather for a location",
        "description": "Returns current weather conditions for the specified location",
        "parameters": [
          {
            "name": "location",
            "in": "query",
            "required": true,
            "description": "The location to get weather for, e.g. 'Seattle, WA'",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Weather data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "location": {
                      "type": "string",
                      "description": "The queried location"
                    },
                    "temperature": {
                      "type": "number",
                      "description": "Temperature in Fahrenheit"
                    },
                    "conditions": {
                      "type": "string",
                      "description": "Current weather conditions"
                    },
                    "humidity": {
                      "type": "number",
                      "description": "Humidity percentage"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing location parameter"
          },
          "401": {
            "description": "Unauthorized - invalid or missing token"
          }
        },
        "security": []
      }
    }
  },
  "components": {}
}
