# AgentCore Identity Sample - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Auth0 Configuration
# ============================================================================

# Your Auth0 tenant domain (without https://)
# Example: agentcore-demo.auth0.com
AUTH0_DOMAIN=

# OAuth 2.0 Client ID from Auth0 Application
AUTH0_CLIENT_ID=

# OAuth 2.0 Client Secret from Auth0 Application
# IMPORTANT: Keep this secret secure! Never commit to version control
AUTH0_CLIENT_SECRET=

# API Audience/Identifier from Auth0 API settings
# Example: https://agentcore-financial-api
AUTH0_AUDIENCE=https://agentcore-financial-api

# OAuth callback URL for your application
# Development: http://localhost:9090/callback
# Production: https://your-domain.com/callback
AUTH0_CALLBACK_URL=http://localhost:9090/callback

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS Region for AgentCore deployment
# AgentCore is available in: us-east-1, us-west-2, ap-southeast-2, eu-west-1
AWS_REGION=ap-southeast-2  # Change to your preferred AWS region

# AWS Profile (optional, uses default if not specified)
AWS_PROFILE=default

# ============================================================================
# AWS Secrets Manager Configuration
# ============================================================================

# Enable AWS Secrets Manager for loading Auth0 credentials
# Set to "true" in production, "false" for local development
# If not set, auto-detects based on AWS environment markers (Lambda, ECS)
USE_SECRETS_MANAGER=false

# Secret name/ARN in AWS Secrets Manager for Auth0 credentials
# The secret should contain JSON with: domain, client_id, client_secret, audience
# Example: aws secretsmanager create-secret --name agentcore/auth0 \
#   --secret-string '{"domain":"...","client_id":"...","client_secret":"...","audience":"..."}'
SECRET_NAME_AUTH0=agentcore/auth0

# Cache TTL for secrets (in seconds, default: 3600 = 1 hour)
# Matches JWT validator cache TTL for consistency
SECRETS_CACHE_TTL=3600

# ============================================================================
# AgentCore Runtime Configuration
# ============================================================================

# Coordinator Agent ID (from CDK deployment output)
COORDINATOR_AGENT_ID=

# Profile Agent ID (from CDK deployment output)
PROFILE_AGENT_ID=

# Accounts Agent ID (from CDK deployment output)
ACCOUNTS_AGENT_ID=

# ============================================================================
# AgentCore Identity Configuration
# ============================================================================

# Identity Pool ID (from CDK deployment output)
AGENTCORE_IDENTITY_POOL_ID=

# JWT Authorizer ID (from CDK deployment output)
AGENTCORE_JWT_AUTHORIZER_ID=

# Memory Service ID for conversation context (from CDK deployment output)
AGENTCORE_MEMORY_ID=

# AgentCore Gateway URL (optional - this sample uses direct AgentCore Runtime)
# Example: https://agentcore.{region}.amazonaws.com
AGENTCORE_GATEWAY_URL=

# ============================================================================
# DynamoDB Configuration
# ============================================================================

# Customer Profile Table Name (from CDK deployment output)
DYNAMODB_PROFILE_TABLE=agentcore-customer-profiles

# Transactions Table Name (optional, if using DynamoDB for transactions)
DYNAMODB_TRANSACTIONS_TABLE=agentcore-transactions

# ============================================================================
# Application Configuration
# ============================================================================

# Enable debug mode (true/false)
# WARNING: Never enable in production!
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Environment (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# Streamlit Configuration
# ============================================================================

# Streamlit server port
STREAMLIT_PORT=8501

# Streamlit server host
STREAMLIT_HOST=localhost

# ============================================================================
# OAuth Callback Server Configuration
# ============================================================================

# OAuth callback server port (for handling Auth0 redirects)
OAUTH_CALLBACK_PORT=9090

# OAuth callback server host
OAUTH_CALLBACK_HOST=localhost

# ============================================================================
# Security Configuration
# ============================================================================

# Token expiration time in seconds (default: 86400 = 24 hours)
TOKEN_EXPIRATION=86400

# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Enable PKCE for OAuth (true/false) - Recommended: true
ENABLE_PKCE=true

# ============================================================================
# Feature Flags
# ============================================================================

# Enable detailed tracing (true/false)
ENABLE_TRACING=false

# Enable request/response logging (true/false)
ENABLE_REQUEST_LOGGING=false

# Enable performance metrics (true/false)
ENABLE_METRICS=false

# ============================================================================
# Rate Limiting
# ============================================================================

# Rate limit per customer (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# Rate limit burst allowance
RATE_LIMIT_BURST=200

# ============================================================================
# Testing Configuration
# ============================================================================

# Test user email (for automated tests)
TEST_USER_EMAIL=test.user@example.com

# Test user password (for automated tests)
# IMPORTANT: Use a test account, never a real user password
TEST_USER_PASSWORD=

# Mock external services in tests (true/false)
MOCK_EXTERNAL_SERVICES=true

# ============================================================================
# Optional: Additional Services
# ============================================================================

# Redis URL for session caching (optional)
# Example: redis://localhost:6379/0
REDIS_URL=

# MongoDB connection string (optional)
# Example: mongodb://localhost:27017/agentcore
MONGODB_URI=

# S3 Bucket for file storage (optional)
S3_BUCKET_NAME=

# ============================================================================
# Monitoring & Observability
# ============================================================================

# CloudWatch Log Group name
CLOUDWATCH_LOG_GROUP=/aws/agentcore/identity-sample

# Enable X-Ray tracing (true/false)
ENABLE_XRAY=false

# Application metrics namespace
METRICS_NAMESPACE=AgentCore/IdentitySample

# ============================================================================
# Development Tools
# ============================================================================

# Enable hot reload for development (true/false)
HOT_RELOAD=true

# Enable auto-refresh for Streamlit (true/false)
AUTO_REFRESH=true

# Show debug toolbar (true/false)
SHOW_DEBUG_TOOLBAR=false

# ============================================================================
# Production-Only Settings
# ============================================================================
# These should only be set in production environments

# Force HTTPS (true/false)
# FORCE_HTTPS=true

# Enable HSTS (HTTP Strict Transport Security)
# ENABLE_HSTS=true

# Content Security Policy
# CSP_POLICY="default-src 'self'"

# Enable CORS (true/false)
# ENABLE_CORS=true

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://your-domain.com

# ============================================================================
# Notes
# ============================================================================
#
# 1. Never commit this file with real values to version control
# 2. Use AWS Secrets Manager for production secrets
# 3. Rotate secrets regularly
# 4. Use different values for each environment
# 5. Keep this file in .gitignore
# 6. Document any custom variables you add
#
# For more information, see:
# - docs/setup.md - Detailed setup instructions
# - docs/auth0_configuration.md - Auth0 configuration guide
# - docs/architecture.md - System architecture
#
# ============================================================================
