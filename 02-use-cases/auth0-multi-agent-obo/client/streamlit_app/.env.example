# Auth0 Configuration
# Get these values from your Auth0 application settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://agentcore-financial-api
AUTH0_CALLBACK_URL=http://localhost:9090/callback

# AgentCore Configuration
# AWS region where your agents are deployed
AWS_REGION=ap-southeast-2  # Change to your preferred AWS region

# AgentCore Agent IDs
# Get these from your AgentCore deployment
COORDINATOR_AGENT_ID=your-coordinator-agent-id
PROFILE_AGENT_ID=your-profile-agent-id
ACCOUNTS_AGENT_ID=your-accounts-agent-id

# AgentCore Identity Configuration
AGENTCORE_IDENTITY_POOL_ID=your-identity-pool-id
AGENTCORE_JWT_AUTHORIZER_ID=your-jwt-authorizer-id

# AgentCore Memory Configuration
AGENTCORE_MEMORY_ID=your-memory-id

# Optional: AgentCore Gateway URL (if using API Gateway)
# AGENTCORE_GATEWAY_URL=https://your-gateway-url.execute-api.region.amazonaws.com/prod

# Application Configuration
# Port for Streamlit application
STREAMLIT_PORT=8501

# Port for OAuth callback server
OAUTH_CALLBACK_PORT=9090
OAUTH_CALLBACK_HOST=localhost

# Debug settings
DEBUG=false
LOG_LEVEL=INFO

# AWS Credentials (if not using AWS CLI profile)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token
