        <mxCell id="step2-text" value="Request Login Initiation" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="420" y="310" width="130" height="20" as="geometry" />
