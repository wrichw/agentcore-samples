        <!-- State Validation Box -->
        <mxCell id="state-validation-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="530" y="900" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="state-validation-text" value="Validate State&#xa;(CSRF Protection)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="535" y="905" width="130" height="40" as="geometry" />
        </mxCell>

        <!-- Step 10: Streamlit to Auth0 - Token Exchange -->
        <mxCell id="step10-label" value="10" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
