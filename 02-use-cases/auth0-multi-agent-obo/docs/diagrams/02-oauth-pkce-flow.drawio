            <mxPoint x="820" y="1115" as="sourcePoint" />
            <mxPoint x="600" y="1115" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step11-text" value="200 OK: { access_token, id_token, refresh_token, expires_in, token_type }" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="610" y="1090" width="200" height="25" as="geometry" />
        </mxCell>

        <!-- JWT Token Visual -->
        <mxCell id="jwt-token-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6ffe6;strokeColor=#00b300;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1060" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="jwt-token-title" value="JWT Access Token Structure" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#00b300;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1065" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="jwt-token-header" value="Header: { &quot;alg&quot;: &quot;RS256&quot;, &quot;typ&quot;: &quot;JWT&quot; }" style="text;html=1;strokeColor=none;fillColor=#ffcccc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1165" y="1090" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="jwt-token-payload" value="Payload: { &quot;iss&quot;: &quot;https://your-tenant.auth0.com/&quot;, &quot;aud&quot;: &quot;your-api&quot;,&#xa;  &quot;sub&quot;: &quot;auth0|user123&quot;, &quot;exp&quot;: ..., &quot;iat&quot;: ...,&#xa;  &quot;customer_id&quot;: &quot;cust_12345&quot;, &quot;account_types&quot;: [...], ... }" style="text;html=1;strokeColor=none;fillColor=#ccccff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1165" y="1115" width="370" height="50" as="geometry" />
        </mxCell>
        <mxCell id="jwt-token-signature" value="Signature: RSASHA256(base64UrlEncode(header) + &quot;.&quot; + base64UrlEncode(payload), privateKey)" style="text;html=1;strokeColor=none;fillColor=#ccffcc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1165" y="1170" width="370" height="20" as="geometry" />
        </mxCell>

        <!-- Step 12: Streamlit - Store Tokens -->
        <mxCell id="step12-label" value="12" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1170" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step12-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="530" y="1160" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="step12-text" value="Store in Session:&#xa;- access_token&#xa;- id_token&#xa;- refresh_token" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="535" y="1165" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Step 13: Show Dashboard -->
        <mxCell id="step13-label" value="13" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1260" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step13-arrow1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="1275" as="sourcePoint" />
            <mxPoint x="380" y="1275" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step13-arrow2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="380" y="1295" as="sourcePoint" />
            <mxPoint x="160" y="1295" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step13-text" value="Display Authenticated Dashboard" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="200" y="1250" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- Divider - API Calls Section -->
        <mxCell id="divider" value="" style="endArrow=none;html=1;strokeWidth=3;strokeColor=#999999;dashed=1;dashPattern=8 8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="100" y="1350" as="sourcePoint" />
            <mxPoint x="1550" y="1350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="divider-text" value="Authenticated API Calls to AgentCore" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="550" y="1330" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- Step 14: User Makes Request -->
        <mxCell id="step14-label" value="14" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1390" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step14-arrow1" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="160" y="1405" as="sourcePoint" />
            <mxPoint x="380" y="1405" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step14-arrow2" value="" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1a73e8;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="380" y="1425" as="sourcePoint" />
            <mxPoint x="600" y="1425" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step14-text" value="User Action (e.g., &quot;Check my account balance&quot;)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="200" y="1380" width="280" height="20" as="geometry" />
        </mxCell>

        <!-- Step 15: Streamlit to AgentCore with JWT -->
        <mxCell id="step15-label" value="15" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1470" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step15-arrow" value="" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#00b300;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="1485" as="sourcePoint" />
            <mxPoint x="1040" y="1485" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step15-text" value="POST /invoke&#xa;Authorization: Bearer {access_token}&#xa;Body: { prompt: &quot;Check account balance&quot; }" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#00b300;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="1445" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- JWT Token Flow Highlight -->
        <mxCell id="jwt-flow-highlight" value="JWT Token Flow: Auth0 -> Streamlit Session -> AgentCore API" style="text;html=1;strokeColor=#00b300;fillColor=#e6ffe6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1;fontColor=#00b300;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1475" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Step 16: AgentCore - Validate JWT -->
        <mxCell id="step16-label" value="16" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1530" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step16-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="970" y="1525" width="140" height="90" as="geometry" />
        </mxCell>
        <mxCell id="step16-text" value="Validate JWT:&#xa;- Verify Signature (RS256)&#xa;- Check Expiration (exp)&#xa;- Validate Issuer (iss)&#xa;- Validate Audience (aud)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="975" y="1530" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- JWT Validation Details -->
        <mxCell id="jwt-validation-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5e6ff;strokeColor=#9673a6;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1520" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="jwt-validation-title" value="JWT Validation by AgentCore" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1525" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="jwt-validation-content" value="1. Fetch JWKS from https://{tenant}.auth0.com/.well-known/jwks.json&#xa;2. Verify RS256 signature using public key&#xa;3. Validate: exp > now, iss == expected_issuer, aud includes api_id&#xa;4. If valid, proceed; if invalid, return 401 Unauthorized" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1550" width="380" height="65" as="geometry" />
        </mxCell>

        <!-- Step 17: AgentCore - Extract Claims -->
        <mxCell id="step17-label" value="17" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1640" width="30" height="30" as="geometry" />
        </mxCell>
        <mxCell id="step17-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="970" y="1635" width="140" height="100" as="geometry" />
        </mxCell>
        <mxCell id="step17-text" value="Extract Claims:&#xa;- customer_id&#xa;- account_types[]&#xa;- scopes&#xa;- kyc_status" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="975" y="1640" width="130" height="90" as="geometry" />
        </mxCell>

        <!-- Claims Usage Box -->
        <mxCell id="claims-usage-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0e6;strokeColor=#ff8c00;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1635" width="400" height="110" as="geometry" />
        </mxCell>
        <mxCell id="claims-usage-title" value="Claims Usage in AgentCore" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#ff8c00;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1640" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="claims-usage-content" value="- customer_id: Used in tool calls to fetch customer-specific data&#xa;- account_types: Filter accessible accounts in database queries&#xa;- scopes: Authorize specific API operations&#xa;- kyc_status: Extracted (not yet enforced)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1160" y="1665" width="380" height="75" as="geometry" />
        </mxCell>

        <!-- AgentCore Processing -->
        <mxCell id="agentcore-process-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="970" y="1760" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="agentcore-process-text" value="Process Request:&#xa;- Execute Agent Logic&#xa;- Call Tools with Claims&#xa;- Generate Response" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="975" y="1765" width="130" height="70" as="geometry" />
        </mxCell>

        <!-- Step 18: AgentCore to Streamlit - Response -->
        <mxCell id="step18-label" value="18" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1870" width="30" height="30" as="geometry" />
