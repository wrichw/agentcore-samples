          <mxGeometry x="350" y="610" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- Step 7: Auth0 Internal - Run Actions -->
        <mxCell id="step7-label" value="7" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="670" width="30" height="30" as="geometry" />
