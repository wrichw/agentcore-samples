        <!-- Security Best Practices Box -->
        <mxCell id="security-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="850" y="2020" width="700" height="120" as="geometry" />
