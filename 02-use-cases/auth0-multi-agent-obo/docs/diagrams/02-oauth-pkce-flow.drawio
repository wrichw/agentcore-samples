            <mxPoint x="820" y="825" as="sourcePoint" />
            <mxPoint x="380" y="825" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step8-text" value="302 Redirect: {redirect_uri}?code={authorization_code}&amp;state={state}" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="430" y="800" width="350" height="20" as="geometry" />
        </mxCell>

        <!-- Step 9: Browser to Streamlit - Authorization Code -->
        <mxCell id="step9-label" value="9" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="860" width="30" height="30" as="geometry" />
