            <mxPoint x="600" y="475" as="sourcePoint" />
            <mxPoint x="380" y="475" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="step3-text" value="Redirect to Auth0 /authorize" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="400" y="450" width="170" height="20" as="geometry" />
        </mxCell>

        <!-- Step 4: Browser to Auth0 - GET /authorize -->
        <mxCell id="step4-label" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a73e8;strokeColor=#1a73e8;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="30" height="30" as="geometry" />
