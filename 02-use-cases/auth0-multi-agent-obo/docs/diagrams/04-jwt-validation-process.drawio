<mxfile host="app.diagrams.net" modified="2024-01-22T00:00:00.000Z" agent="Claude" version="22.1.0" type="device">
  <diagram id="jwt-validation-process" name="JWT Token Validation Process">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="JWT Token Validation Process" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="225" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: JWT Token Arrives (Starting Point - Green) -->
        <mxCell id="step1" value="&lt;b&gt;JWT Token Arrives&lt;/b&gt;&lt;br&gt;&lt;i&gt;(Starting Point)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 1-2 -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 2: Extract from Authorization Header (Blue - Extraction) -->
        <mxCell id="step2" value="&lt;b&gt;Extract from Authorization Header&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot;&gt;Bearer &amp;lt;token&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="160" width="250" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 2-3 -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Parse JWT Structure (Blue - Extraction) -->
        <mxCell id="step3" value="&lt;b&gt;Parse JWT Structure&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Header&lt;br&gt;- Payload&lt;br&gt;- Signature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="250" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- Arrow 3-4 -->
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: Fetch JWKS from Auth0 (Blue - Extraction) -->
        <mxCell id="step4" value="&lt;b&gt;Fetch JWKS from Auth0&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 10px;&quot;&gt;https://tenant.auth0.com/&lt;br&gt;.well-known/jwks.json&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="360" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 4-5 -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: Verify Signature (Yellow - Validation Diamond) -->
        <mxCell id="step5" value="&lt;b&gt;Verify Signature&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Get public key from JWKS&lt;br&gt;- Verify RS256 signature" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="275" y="460" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow 5-6 -->
        <mxCell id="arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6: Validate Claims (Yellow - Validation Diamond) -->
        <mxCell id="step6" value="&lt;b&gt;Validate Claims&lt;/b&gt;&lt;br&gt;&lt;br&gt;- iss: correct issuer?&lt;br&gt;- aud: correct audience?&lt;br&gt;- exp: not expired?&lt;br&gt;- iat: issued in past?&lt;br&gt;- nbf: not before check" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="610" width="350" height="150" as="geometry" />
        </mxCell>

        <!-- Arrow 6-7 -->
        <mxCell id="arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step6" target="step7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 7: Extract Custom Claims (Blue - Extraction) -->
        <mxCell id="step7" value="&lt;b&gt;Extract Custom Claims&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 11px;&quot;&gt;- namespace/customer_id&lt;br&gt;- namespace/account_types&lt;br&gt;- namespace/kyc_status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="790" width="250" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 7-8 -->
        <mxCell id="arrow7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step7" target="step8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 8: Build User Context (Blue - Extraction) -->
        <mxCell id="step8" value="&lt;b&gt;Build User Context&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font face=&quot;Courier New&quot; style=&quot;font-size: 10px;&quot;&gt;{&lt;br&gt;  &quot;userId&quot;: &quot;auth0|123&quot;,&lt;br&gt;  &quot;customerId&quot;: &quot;cust_456&quot;,&lt;br&gt;  &quot;account_types&quot;: [&quot;checking&quot;, &quot;savings&quot;],&lt;br&gt;  &quot;kyc_status&quot;: &quot;verified&quot;,&lt;br&gt;  &quot;scopes&quot;: [&quot;read:accounts&quot;]&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="920" width="250" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow 8-9 -->
        <mxCell id="arrow8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step8" target="step9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 9: Authorize Operation (Yellow - Validation Diamond) -->
        <mxCell id="step9" value="&lt;b&gt;Authorize Operation&lt;/b&gt;&lt;br&gt;&lt;br&gt;- Check scopes&lt;br&gt;- Verify resource access&lt;br&gt;- Validate account types" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="275" y="1080" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- Arrow 9-10 -->
        <mxCell id="arrow9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="step9" target="step10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 10: Execute Agent Operation (Green - End Point) -->
        <mxCell id="step10" value="&lt;b&gt;Execute Agent Operation&lt;/b&gt;&lt;br&gt;&lt;i&gt;(End Point)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="1230" width="250" height="50" as="geometry" />
        </mxCell>

